# Optional: when empty, the project uses local Ollama.
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# Local Ollama fallback.
OLLAMA_MODEL=qwen2:0.5b
OLLAMA_CHAT_URL=http://localhost:11434/api/chat

# LLM request settings.
LLM_TIMEOUT_SECONDS=60
LLM_MAX_TOKENS=256

# Retrieval and verification thresholds.
RAG_MIN_SCORE=0.12
VERIFY_MIN_SCORE=0.18
VERIFY_MIN_MARGIN=0.035
COVE_MIN_SCORE=0.16
COVE_KEYWORD_COVERAGE=0.45
